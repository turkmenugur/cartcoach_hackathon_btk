# BUFF Store Gemini API Configuration
# Replace 'YOUR_GEMINI_API_KEY' with your actual Google Gemini API key
GOOGLE_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Optional: n8n cart rescue webhook
# N8N_WEBHOOK_URL=https://your-n8n-instance/webhook/buff-store-cart-rescue

# Supabase data layer
SUPABASE_URL=https://egshytpkqjgxupoxzunz.supabase.co
# Server writes require service role key. Keep this only in backend .env, never frontend.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE
# Read-only fallback if you only want reads.
# SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# Frontend (cartcoach-frontend/.env.local)
# NEXT_PUBLIC_BUFF_STORE_API_URL=http://127.0.0.1:8000
# NEXT_PUBLIC_CARTCOACH_API_URL=http://127.0.0.1:8000
